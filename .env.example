# =============================================================================
# WhatsApp AI SaaS - Environment Configuration
# =============================================================================
# SECURITY: Copy to .env and fill with real values. Never commit .env to git.
# =============================================================================

# DATABASE — MongoDB connection string (local or Atlas)
# Format: mongodb+srv://user:pass@cluster.mongodb.net/dbname?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/whatsapp-sass

# SERVER
PORT=3000
NODE_ENV=development

# JWT — minimum 32 characters in production
JWT_SECRET=change-me-use-openssl-rand-base64-32-min-32-chars

# AES-256-GCM — exactly 64 hex characters (32 bytes)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# CORS — production: comma-separated origins; dev often uses *
CORS_ORIGIN=*

# AI
AI_REPLY_MAX_PER_MINUTE=30
AI_MEMORY_MAX_MESSAGES=100
AI_DEBOUNCE_MS=3000
AI_DEBOUNCE_MAX_BUFFER_MSGS=6
AI_DEBOUNCE_MAX_WAIT_MS=10000

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=
# OPENROUTER_HTTP_REFERER=https://your-app.example.com
# OPENROUTER_APP_TITLE=WhatsApp SaaS

# Campaigns (optional overrides; see src/config/env.ts for defaults)
# CAMPAIGN_MAX_RECIPIENTS=5000
